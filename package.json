{
  "name": "better-gdrive",
  "version": "0.1.1",
  "description": "Download files from public Google Drive. Get direct download URLs or fetch as Blob/Buffer. No OAuth required.",
  "keywords": [
    "google-drive",
    "download",
    "drive",
    "public",
    "file",
    "blob",
    "fetch",
    "no-oauth"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Sn4tchZ/better-gdrive.git"
  },
  "bugs": {
    "url": "https://github.com/Sn4tchZ/better-gdrive/issues"
  },
  "homepage": "https://github.com/Sn4tchZ/better-gdrive#readme",
  "author": "Sn4tchZ",
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test:behavior": "node scripts/test-gdrive-behavior.mjs",
    "probe": "node scripts/fetch-probe.mjs"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  }
}
